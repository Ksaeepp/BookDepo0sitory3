<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="ru.kurepin.bookdepository">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BookDepository">

        <!-- Главная активность (список книг) -->
        <activity
            android:name=".BookListActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ========== ШАГ 9: ВКЛЮЧЕНИЕ КНОПКИ UP ==========
             Атрибут parentActivityName указывает, какая активность является родительской.
             При нажатии кнопки Up (стрелка влево на панели инструментов) система
             откроет BookListActivity, обеспечивая иерархическую навигацию.
        -->
        <activity
            android:name=".BookPagerActivity"
            android:label="@string/app_name"
            android:parentActivityName=".BookListActivity" />

    </application>
</manifest>
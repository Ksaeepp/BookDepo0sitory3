<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Поле для ввода названия книги -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Название книги:"
        android:textSize="14sp"
        android:textColor="@android:color/darker_gray"/>

    <EditText
        android:id="@+id/book_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Введите название книги"
        android:textSize="18sp"
        android:layout_marginBottom="16dp"/>

    <!-- Поле для отображения даты -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Дата добавления:"
        android:textSize="14sp"
        android:textColor="@android:color/darker_gray"/>

    <TextView
        android:id="@+id/book_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="01.01.2024"
        android:textSize="16sp"
        android:padding="12dp"
        android:background="@android:drawable/editbox_background"
        android:layout_marginBottom="8dp"/>

    <!-- Кнопка выбора даты -->
    <Button
        android:id="@+id/book_date_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Выбрать дату"
        android:layout_marginBottom="16dp"/>

    <!-- Чекбокс статуса прочтения -->
    <CheckBox
        android:id="@+id/book_readed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Прочитана"
        android:textSize="16sp"
        android:layout_marginBottom="16dp"/>

    <!-- НОВАЯ КНОПКА ДЛЯ ОТПРАВКИ ОТЧЁТА (ШАГ 2) -->
    <Button
        android:id="@+id/book_report"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/book_report_text"
        android:drawableLeft="@android:drawable/ic_menu_send"
        android:padding="12dp"
        android:layout_marginBottom="8dp"/>

    <!-- Кнопка возврата назад -->
    <Button
        android:id="@+id/back_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Назад"
        android:drawableLeft="@android:drawable/ic_menu_revert"
        android:padding="12dp"/>

</LinearLayout>